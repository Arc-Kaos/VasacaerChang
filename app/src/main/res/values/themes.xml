<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema principal de la app -->
    <style name="Theme.NexusPay" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash del Sistema: Lo hacemos invisible para que solo se vea tu pantalla de branding personalizada -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_void</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.NexusPay</item>
    </style>
</resources>